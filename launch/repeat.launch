<!-- vtr/launch/repeat.launch -->
<!--
    Launches the complete Repeat phase pipeline:
        step3_orb_node         — CLAHE + ORB extraction (reused from Teach)
        step7_geometry_engine  — RANSAC + LK fallback → path_error
        step8_pid_controller   — PID + Ackermann → /cmd_vel

    Usage:
        roslaunch vtr repeat.launch goal:="Lab door"
        roslaunch vtr repeat.launch goal:="Office 204" base_speed:=0.2

    To start the robot moving:
        rosservice call /repeat/start

    To stop immediately:
        rosservice call /repeat/stop

    Monitor:
        rostopic echo /pid/debug
        rostopic echo /geometry/result
        rqt_image_view /geometry/debug_image
-->

<launch>

  <!-- ── Arguments ─────────────────────────────────────────────── -->
  <arg name="goal"            default=""/>
  <arg name="graph_path"      default="$(env HOME)/vtr_graph"/>
  <!-- NEW: VO waypoints from teach phase -->
  <arg name="waypoints_pkl"   default="$(env HOME)/waypoints.pkl"/>
  <arg name="calib_path"      default="$(find vtr)/config/calibration.yaml"/>
  <arg name="base_speed"      default="0.3"/>
  <arg name="Kp"              default="0.8"/>
  <arg name="Ki"              default="0.02"/>
  <arg name="Kd"              default="0.1"/>
  <!-- NEW: ORB match score threshold for checkpoint snapping -->
  <arg name="orb_threshold"   default="0.75"/>
  <arg name="debug_viz"       default="true"/>


  <!-- NEW: LK optical flow node — primary navigation backbone -->
  <node pkg="vtr" type="lk_flow_node.py"
        name="lk_flow_node" output="screen">
    <param name="max_corners"     value="200"/>
    <param name="quality_level"   value="0.01"/>
    <param name="min_dist"        value="10.0"/>
    <param name="win_size"        value="21"/>
    <param name="max_level"       value="3"/>
    <param name="redetect_thresh" value="20"/>
  </node>

  <!-- NEW: Fusion node — ORB checkpoint arbitration -->
  <node pkg="vtr" type="fusion_node.py"
        name="fusion_node" output="screen">
    <!-- Expose ORB_THRESHOLD as a launch arg so it can be tuned at launch time -->
    <param name="orb_threshold"   value="$(arg orb_threshold)"/>
    <param name="snap_cooldown_s" value="1.0"/>
  </node>

 <node pkg="vtr" type="repeat_controller.py"
        name="repeat_controller" output="screen">
    <param name="graph_path"      value="$(arg graph_path)"/>
    <!-- NEW: VO waypoints from teach phase -->
    <param name="waypoints_pkl"   value="$(arg waypoints_pkl)"/>
    <param name="goal_label"      value="$(arg goal)"/>
    <!-- NEW: P-gain for flow-error steering correction -->
    <param name="Kp"              value="$(arg Kp)"/>
    <param name="min_inliers"     value="15"/>
    <param name="advance_votes"   value="2"/>
    <param name="failure_timeout" value="3.0"/>
    <param name="lookahead"       value="3"/>
    <param name="endpoint_hold"   value="1.0"/>
    <param name="publish_rate"    value="20.0"/>
  </node>

  <!-- ── Step 7: Geometry engine ────────────────────────────────────── -->
  <node pkg="vtr" type="geometry_engine.py"
        name="geometry_engine" output="screen">
    <param name="calib_path"        value="$(arg calib_path)"/>
    <param name="lowe_ratio"        value="0.75"/>
    <param name="ransac_threshold"  value="1.0"/>
    <param name="ransac_prob"       value="0.999"/>
    <param name="min_inliers"       value="15"/>
    <param name="lk_threshold"      value="15"/>
    <param name="w_lateral"         value="0.7"/>
    <param name="w_yaw"             value="0.3"/>
    <param name="clip_limit"        value="2.0"/>
    <param name="n_features"        value="500"/>
    <param name="debug_viz"         value="$(arg debug_viz)"/>
  </node>

  <!-- ── Step 8: PID controller ─────────────────────────────────────── -->
  <node pkg="vtr" type="pid_controller.py"
        name="pid_controller" output="screen">
    <param name="Kp"              value="$(arg Kp)"/>
    <param name="Ki"              value="$(arg Ki)"/>
    <param name="Kd"              value="$(arg Kd)"/>
    <param name="base_speed"      value="$(arg base_speed)"/>
    <param name="max_steer"       value="0.6"/>
    <param name="dead_band_tight" value="0.05"/>
    <param name="dead_band_wide"  value="0.15"/>
    <param name="max_integral"    value="0.5"/>
    <param name="cmd_rate"        value="20.0"/>
    <param name="timeout"         value="0.5"/>
  </node>

</launch>

